# MySQL Configuration
# Copy this file to .env and update the values as needed
MYSQL_ROOT_PASSWORD=your_password

# Source (Master) Database Configuration
# This is the database that contains the data to be archived
TEST_SOURCE_HOST=127.0.0.1
TEST_SOURCE_PORT=3305
TEST_SOURCE_USER=root
TEST_SOURCE_PASSWORD=your_password
TEST_SOURCE_DB=sakila

# Destination (Archive) Database Configuration
# This is the database where archived data will be stored, and where GoArchive
# writes its archiver_job / archiver_job_log state tables.
TEST_DEST_HOST=127.0.0.1
TEST_DEST_PORT=3307
TEST_DEST_USER=root
TEST_DEST_PASSWORD=your_password
TEST_DEST_DB=sakila_archive

# Replica Database Configuration (optional)
# Used for replication-lag testing
TEST_REPLICA_HOST=127.0.0.1
TEST_REPLICA_PORT=3308
TEST_REPLICA_USER=root
TEST_REPLICA_PASSWORD=your_password

# Sakila Database Directory (optional)
# Leave unset to let the JS scripts use the repo-relative default
# (tests/sakila-db). Set to an absolute path only if your files live elsewhere.
# NOTE: do not uncomment with an empty value — .env is sourced with `set -a`
# and would clobber any exported override.
# SAKILA_DIR=/absolute/path/to/sakila-db

# Dump Directory (optional)
# Override the default location for schema dumps
DUMP_DIR=/tmp/db1_schema_dump
