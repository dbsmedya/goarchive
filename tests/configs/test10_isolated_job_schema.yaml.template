# Test 10: Isolated Job Schema
# Tests archiving with job_schema pointing to a separate dedicated schema
# (goarchive_meta) rather than the default destination database.
#
# Purpose: verifies the end-to-end path where tracking tables (archiver_job,
# archiver_job_log_<id>) land in a schema that is separate from the archive
# destination DB. The goarchive_meta schema must be pre-created before running
# (run-tests.sh does this automatically as part of test 10).
#
# Hierarchy:
# film (root)
#   ├── film_actor (1-N)
#   ├── film_category (1-N)
#   └── inventory (1-N)
#         └── rental (1-N)
#               └── payment (1-N)
#
# Copy this file to test10_isolated_job_schema.yaml and substitute the password
# (or render ${MYSQL_ROOT_PASSWORD} from tests/.env) before running.

source:
  host: 127.0.0.1
  port: 3305
  user: root
  password: ${MYSQL_ROOT_PASSWORD}
  database: sakila

destination:
  host: 127.0.0.1
  port: 3307
  user: root
  password: ${MYSQL_ROOT_PASSWORD}
  database: sakila_archive
  job_schema: goarchive_meta

safety:
  disable_foreign_key_checks: true

jobs:
  archive-isolated-job-schema:
    root_table: film
    primary_key: film_id
    # Archive first 10 films to keep test manageable
    where: "film_id <= 10"
    # Small batch size to exercise multi-batch copy/delete chunking end-to-end
    processing:
      batch_size: 50
      batch_delete_size: 50
    relations:
      # 1-N: Film has many actors (via junction table)
      - table: film_actor
        primary_key: actor_id
        foreign_key: film_id
        dependency_type: "1-N"

      # 1-N: Film has many categories (via junction table)
      - table: film_category
        primary_key: category_id
        foreign_key: film_id
        dependency_type: "1-N"

      # 1-N: Film has many inventory items
      - table: inventory
        primary_key: inventory_id
        foreign_key: film_id
        dependency_type: "1-N"
        relations:
          # 1-N: Inventory item has many rentals
          - table: rental
            primary_key: rental_id
            foreign_key: inventory_id
            dependency_type: "1-N"
            relations:
              # 1-N: Rental has many payments
              - table: payment
                primary_key: payment_id
                foreign_key: rental_id
                dependency_type: "1-N"
